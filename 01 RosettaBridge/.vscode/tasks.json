{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Ejecutar Código Políglota",
            "type": "process",
            "command": "./run_polyglot.sh",
            "args": [
                "${file}",
                "${fileDirname}",
                "${fileBasenameNoExtension}"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "showReuseMessage": false,
                "clear": true
            },
            "problemMatcher": []
        }
    ]
}